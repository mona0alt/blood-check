<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BloodCheck" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brandPrimary</item>
        <item name="colorOnPrimary">@color/brandOnPrimary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- 浅色状态栏区域：系统时间/电量/Wi‑Fi 等使用深色图标，在薄荷绿顶栏上可读 -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surfaceTint</item>
    </style>

    <!-- 设置弹窗：白底 + 主色按钮/强调文字，与设计稿一致 -->
    <style name="ThemeOverlay.BloodCheck.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/design_primary_teal</item>
        <item name="colorOnPrimary">@color/design_card_white</item>
        <item name="colorSurface">@color/design_card_white</item>
        <item name="colorOnSurface">@color/design_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/design_text_secondary</item>
        <item name="android:colorBackground">@color/design_card_white</item>
    </style>
</resources>
