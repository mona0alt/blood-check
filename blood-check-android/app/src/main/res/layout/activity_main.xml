<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/uni_page_bg"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/design_header_bg" />

    <!-- 顶部标题（首页 / 我的 共用占位，我的页会改文案） -->
    <FrameLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/design_header_bg">

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/hemoglobin_screen_title"
            android:textColor="@color/design_header_title"
            android:textSize="17sp" />

        <LinearLayout
            android:id="@+id/layoutHeaderActions"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="6dp">

            <ImageView
                android:id="@+id/btnDataCollect"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_data_collect"
                android:padding="9dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_data_collect" />

            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="4dp"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:text="\u2699"
                android:textColor="@color/design_primary_teal"
                android:textSize="18sp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fadeScrollbars="false"
            android:fillViewport="false"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="vertical"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/main_scroll_bottom_padding">

                <LinearLayout
                    android:id="@+id/layoutBleStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card_white_rounded"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp">

                    <View
                        android:id="@+id/viewBleStatusDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_ble_status_dot" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/ble_status_label"
                        android:textColor="@color/design_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBleStatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="end"
                        android:maxLines="1"
                        android:text="@string/ble_status_checking"
                        android:textColor="@color/ble_status_idle"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- 患者信息（白卡片） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card_white_rounded"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvPatientIdRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/design_primary_teal"
                        android:textSize="14sp"
                        tools:text="患者ID 123" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvPatientName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/design_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                tools:text="张三" />

                            <ImageView
                                android:id="@+id/ivPatientGenderIcon"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="5dp"
                                android:contentDescription="@string/field_gender"
                                android:scaleType="fitCenter"
                                android:visibility="gone"
                                tools:src="@drawable/nv"
                                tools:visibility="visible" />

                            <TextView
                                android:id="@+id/tvPatientGender"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/design_text_secondary"
                                android:textSize="15sp"
                                tools:text="女"
                                tools:visibility="visible" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvPatientAge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/design_text_primary"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            tools:text="56岁" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 图表区 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_chart_container"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/chart_y_hb"
                            android:textColor="@color/uni_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="@string/chart_y_lac"
                            android:textColor="@color/uni_text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/viewLegendHb"
                                android:layout_width="28dp"
                                android:layout_height="3dp"
                                android:background="@color/design_chart_line_hb" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="@string/legend_hb"
                                android:textColor="@color/uni_text_primary"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <Space
                            android:layout_width="20dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/viewLegendLac"
                                android:layout_width="28dp"
                                android:layout_height="3dp"
                                android:background="@color/design_chart_line_lac" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="@string/legend_lac"
                                android:textColor="@color/uni_text_primary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.bloodcheck.app.HemoglobinMonitorChartView
                        android:id="@+id/chartMonitor"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:text="@string/chart_x_label"
                        android:textColor="@color/uni_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- 监护数据 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_monitor_card"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/monitoring_data_title"
                            android:textColor="@color/design_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnResetAlarm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_btn_reset_alarm"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="30dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/reset_alarm"
                            android:textAllCaps="false"
                            android:textColor="@color/uni_white"
                            android:textSize="11sp"
                            app:backgroundTint="@null" />
                    </LinearLayout>

                    <include layout="@layout/include_monitor_row_hb_lac" />

                    <include layout="@layout/include_monitor_row_pi_spo2" />

                    <include layout="@layout/include_monitor_row_pao2_hr" />

                    <include layout="@layout/include_monitor_row_fo2hb_glucose" />

                    <include layout="@layout/include_monitor_row_k_na" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvMonitoringPatientId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="6dp"
                    android:textColor="@color/design_text_hint"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:text="ID: 123"
                    tools:visibility="visible" />

                <LinearLayout
                    android:id="@+id/layoutBottomInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="0dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartMonitor"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_btn_start_monitor"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/start_monitor"
                        android:textColor="@color/uni_white"
                        app:backgroundTint="@null" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutMonitorActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopMonitor"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_btn_stop_monitor"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/stop_monitor"
                        android:textColor="@color/uni_white"
                        app:backgroundTint="@null"
                        app:icon="@drawable/tingzhijiance"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="22dp"
                        app:iconTint="@color/uni_white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExport"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/export_data"
                        android:textColor="@color/design_primary_teal"
                        app:strokeColor="@color/design_primary_teal"
                        app:strokeWidth="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollMine"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fadeScrollbars="false"
            android:fillViewport="false"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/main_scroll_bottom_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_mine_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:text="@string/mine_card_title"
                        android:textColor="@color/uni_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/uni_border" />

                    <LinearLayout
                        android:id="@+id/layoutMineContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_patient_id" />

                            <TextView
                                android:id="@+id/tvMineValPatientId"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_unified_id" />

                            <TextView
                                android:id="@+id/tvMineValUnified"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_hospital" />

                            <TextView
                                android:id="@+id/tvMineValHospital"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_name" />

                            <TextView
                                android:id="@+id/tvMineValName"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_gender" />

                            <TextView
                                android:id="@+id/tvMineValGender"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_age" />

                            <TextView
                                android:id="@+id/tvMineValAge"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_temp" />

                            <TextView
                                android:id="@+id/tvMineValTemp"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_hr" />

                            <TextView
                                android:id="@+id/tvMineValHr"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_spo2" />

                            <TextView
                                android:id="@+id/tvMineValSpo2"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_pao2" />

                            <TextView
                                android:id="@+id/tvMineValPao2"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/MineInfoRowContainer">

                            <TextView
                                style="@style/MineInfoRowLabel"
                                android:text="@string/mine_row_o2hb" />

                            <TextView
                                android:id="@+id/tvMineValO2hb"
                                style="@style/MineInfoRowValue" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMineEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingVertical="48dp"
                        android:text="@string/mine_empty"
                        android:textColor="@color/uni_text_hint"
                        android:textSize="14sp"
                        android:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutMineFileCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_mine_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:text="@string/mine_file_card_title"
                        android:textColor="@color/uni_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/uni_border" />

                    <TextView
                        android:id="@+id/tvMineFileCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/design_text_secondary"
                        android:textSize="13sp"
                        tools:text="共 2 个数据集" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMineFileRefresh"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text="@string/file_action_refresh"
                            android:textAllCaps="false"
                            android:textColor="@color/design_primary_teal"
                            app:strokeColor="@color/design_primary_teal"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMineFileToggleSelection"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text="@string/file_action_select_all"
                            android:textAllCaps="false"
                            android:textColor="@color/design_primary_teal"
                            app:strokeColor="@color/design_primary_teal"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMineFileDelete"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text="@string/file_action_delete"
                            android:textAllCaps="false"
                            android:textColor="@color/design_primary_teal"
                            app:strokeColor="@color/design_primary_teal"
                            app:strokeWidth="1dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutMineFileList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/tvMineFileEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingVertical="28dp"
                        android:text="@string/file_empty"
                        android:textColor="@color/uni_text_hint"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/uni_border" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:background="@color/uni_white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="4dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivNavHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/nav_home"
                android:scaleType="fitCenter"
                android:src="@drawable/shouye" />

            <TextView
                android:id="@+id/tvNavHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                android:textColor="@color/uni_nav_active"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navMine"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivNavMine"
                android:layout_width="24dp"
